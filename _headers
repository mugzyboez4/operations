# Allow Airtable Interfaces to iframe-embed the SMT dashboard.
# X-Frame-Options ALLOW-FROM is deprecated; modern browsers use CSP frame-ancestors.
/smt/*
  Content-Security-Policy: frame-ancestors 'self' https://*.airtable.com https://airtable.com https://*.airtableblocks.com https://airtableblocks.com https://*.airtableusercontent.com
