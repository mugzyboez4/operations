# Allow embedding from any origin (Airtable, SharePoint, etc.)
# Note: frame-ancestors MUST be set via HTTP header (meta tag is ignored by browsers)

/smt/*
  Content-Security-Policy: frame-ancestors *
  Permissions-Policy: clipboard-write=*, fullscreen=*

/smt
  Content-Security-Policy: frame-ancestors *

/smt/
  Content-Security-Policy: frame-ancestors *

/artists/*
  Content-Security-Policy: frame-ancestors *
